# Censys Platform (https://platform.censys.io)
# Personal Access Token + Organization ID (la API antigua api_id/secret está retirada).
CENSYS_PAT=""
CENSYS_ORG_ID=""

# VirusTotal (https://www.virustotal.com/gui/join-us)
VIRUSTOTAL_API_KEY=""

# AlienVault OTX (https://otx.alienvault.com/)
ALIENVAULT_API_KEY=""

# Hunter.io (https://hunter.io/)
HUNTER_API_KEY=""

# IPinfo (https://ipinfo.io/)
IPINFO_API_KEY=""

# IPdata (https://ipdata.co/)
IPDATA_API_KEY=""

# Netlas (https://netlas.io/)
NETLAS_API_KEY=""

# urlscan.io (https://urlscan.io/)
URLSCAN_API_KEY=""

# AbuseIPDB (https://www.abuseipdb.com/)
ABUSEIPDB_API_KEY=""

# BeVigil (https://bevigil.com/)
BEVIGIL_API_KEY=""

# NVD API (https://nvd.nist.gov)
NVD_API_KEY=""

# Have I Been Pwned (https://haveibeenpwned.com/API/Key)
# REQUIERE SUSCRIPCIÓN DE PAGO (desde ~3,50 USD/mes). El plan gratuito no permite
# aprovisionar una clave API. Sin clave, la Fase 4 usa XposedOrNot (gratis).
HIBP_API_KEY=""

# Intelligence X — dark web, Pastebin, buckets S3, foros de hacking...
# IMPORTANTE: el plan "Open Source" gratuito (https://intelx.io/?s=opensource)
# NO incluye acceso API programático (devuelve 403). Para uso en esta herramienta
# se necesita un plan de pago (https://intelx.io/product).
INTELX_API_KEY=""

# Pastebin Pro API — feed de pastes en tiempo real (opcional).
# Requiere cuenta Pro en https://pastebin.com/pro ($8.95/mes o $47.88/año).
# Sin esta clave Pastebin no se monitoriza. Con ella se comprueban los 250 pastes
# más recientes en busca de menciones del dominio objetivo.
PASTEBIN_API_KEY=""

# Correos adicionales a vigilar en filtraciones (separados por comas).
# Deja vacío: la herramienta auto-descubre los correos del dominio desde Hunter.io.
MONITOR_EMAILS=""

# Canales de Telegram extra a vigilar (además de los integrados), separados por
# comas. Acepta '@canal', 'canal' o 't.me/canal'. Se buscan menciones del dominio
# en su histórico público (t.me/s/) y se extraen IOCs de cada mensaje.
# Ej.: TELEGRAM_CHANNELS="@leakzone, t.me/breach_db, micanal"
TELEGRAM_CHANNELS=""

#GitHub (https://github.com/) — scope mínimo: public_repo
GITHUB_TOKEN=""

#GitLab (https://gitlab.com/)
GITLAB_TOKEN=""

# ─────────────────────────────────────────────────────────────────────────────
# CREDENCIALES FILTRADAS — búsqueda por dominio en bases de datos de brechas
# Estas fuentes son las más importantes para detectar credenciales, emails,
# contraseñas y datos personales expuestos de empleados o clientes.
# ─────────────────────────────────────────────────────────────────────────────

# LeakCheck.io (https://leakcheck.io) — DE PAGO para búsqueda por DOMINIO
# Busca credenciales filtradas. OJO: el registro gratuito da una clave válida,
# pero la búsqueda por DOMINIO de la API v2 (que usa esta herramienta) exige un
# plan de pago activo; sin él, la API responde 403 "Active plan required".
# 1. Regístrate en https://leakcheck.io y contrata un plan que incluya la API v2.
# 2. Ve a tu perfil → API → copia tu clave.
# Sin plan activo, la herramienta lo detecta y sigue sin esta fuente.
LEAKCHECK_API_KEY=""

# Dehashed (https://dehashed.com) — PAGO ($5.49/mes o $14.99/año)
# La BD de brechas más grande (~15 mil millones de registros).
# Busca por dominio y devuelve: email, usuario, contraseña, IP, nombre real.
# 1. Crea cuenta en https://dehashed.com
# 2. Tu API key aparece en https://dehashed.com/profile
DEHASHED_EMAIL=""          # el email con el que te registraste en Dehashed
DEHASHED_API_KEY=""        # tu API key de Dehashed
